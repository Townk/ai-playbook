}

_ask() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '1: :->cmd' \
    '*::arg:->args'

  case $state in
    cmd)
      _ask_commands
      ;;
    args)
      case $words[1] in
        confirm)
          _ask_cmd_confirm
          ;;
        line)
          _ask_cmd_line
          ;;
        text)
          _ask_cmd_text
          ;;
        choose)
          _ask_cmd_choose
          ;;
        form)
          _ask_cmd_form
          ;;
      esac
      ;;
  esac
}

_ask "$@"
